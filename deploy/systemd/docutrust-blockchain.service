[Unit]
Description=DocuTrust Blockchain Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/docutrust/current/blockchain-service
Environment=NODE_ENV=production
Environment=PATH=/usr/local/bin:/usr/bin:/bin
EnvironmentFile=-/var/www/docutrust/shared/.env
ExecStart=/usr/bin/env node src/index.js
Restart=always
RestartSec=5
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
