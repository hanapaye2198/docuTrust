# Example environment file for /etc/default/docutrust-queue
# Used by deploy/systemd/docutrust-queue@.service
#
# These settings apply to all queue worker instances unless overridden
# by a systemd drop-in for a specific instance.

QUEUE_CONNECTION=redis
QUEUE_SLEEP=1
QUEUE_TRIES=3
QUEUE_TIMEOUT=90
QUEUE_MAX_TIME=3600
QUEUE_MEMORY=512

# Optional extra flags appended to `php artisan queue:work`
# Examples:
# QUEUE_EXTRA_ARGS=--backoff=5
# QUEUE_EXTRA_ARGS=--backoff=5 --rest=1
QUEUE_EXTRA_ARGS=
