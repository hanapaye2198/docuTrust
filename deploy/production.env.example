APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.example

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=docutrust
DB_USERNAME=docutrust
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

DOCUTRUST_QUEUE_DOCUMENTS=documents
DOCUTRUST_QUEUE_NOTIFICATIONS=notifications
DOCUTRUST_QUEUE_PAYMENTS=payments
DOCUTRUST_QUEUE_EINVOICES=einvoices
DOCUTRUST_QUEUE_BLOCKCHAIN=blockchain

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=DocuTrust

FILESYSTEM_DISK=local
DOCUTRUST_FILESYSTEM_DISK=local

BLOCKCHAIN_SERVICE_URL=http://127.0.0.1:3001
BLOCKCHAIN_SERVICE_TIMEOUT=10
LIVEWIRE_CSP_SAFE=true

# Polygon anchoring sidecar:
# - Use a dedicated backend Polygon wallet for signing anchor transactions.
# - If you are using Coins.ph custody, place that wallet's Polygon private key
#   here and fund it for gas on the selected Polygon network.
# - POLYGON_RPC_URL should point at your Polygon RPC provider.
# - DOCUMENT_NOTARY_ADDRESS should be the deployed DocumentNotary contract.

DOCUTRUST_OPENSSL_CONFIG=/etc/ssl/openssl.cnf
DOCUTRUST_ROOT_CA_PRIVATE_KEY_PATH=/var/www/docutrust/shared/keys/root-ca.pem
DOCUTRUST_SIGNING_BACKEND=remote_managed
DOCUTRUST_ROOT_CA_NAME="DocuTrust Root CA"
DOCUTRUST_ROOT_CA_COUNTRY=PH
DOCUTRUST_ROOT_CA_VALID_DAYS=3650
DOCUTRUST_SIGNER_CERT_VALID_DAYS=825

REMOTE_SIGNING_PROVIDER_NAME=trust_service_provider
REMOTE_SIGNING_BASE_URL=
REMOTE_SIGNING_TIMEOUT=10
REMOTE_SIGNING_API_KEY=
REMOTE_SIGNING_API_MODE=csc
REMOTE_SIGNING_DEFAULT_CREDENTIAL_ID=
REMOTE_SIGNING_CSC_SIGN_HASH_ENDPOINT=/csc/v1/signatures/signHash
REMOTE_SIGNING_CSC_HASH_ALGORITHM=2.16.840.1.101.3.4.2.1
REMOTE_SIGNING_CSC_SIGN_ALGORITHM=1.2.840.113549.1.1.11

POLYGON_NETWORK=amoy
POLYGON_RPC_URL=
POLYGON_PRIVATE_KEY=
DOCUMENT_NOTARY_ADDRESS=
