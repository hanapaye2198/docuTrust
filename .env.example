APP_NAME=DocuTrust
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
# Must be >= longest client idle timeout (see DOCUTRUST_IDLE_APP_MINUTES); default 30 minutes.
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Client idle warning/logout (minutes). SESSION_LIFETIME must be >= DOCUTRUST_IDLE_APP_MINUTES.
# DOCUTRUST_IDLE_ONBOARDING_MINUTES=10
# DOCUTRUST_IDLE_ONBOARDING_WARNING_MINUTES=9
# DOCUTRUST_IDLE_APP_MINUTES=20
# DOCUTRUST_IDLE_APP_WARNING_MINUTES=19

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Secure working document/signature store. Keep this private.
# DOCUTRUST_FILESYSTEM_DISK=local
# Long-term completed-document archive. Can point to the same disk or to a
# private cloud bucket such as s3.
# DOCUTRUST_ARCHIVE_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

BLOCKCHAIN_SERVICE_URL=http://127.0.0.1:3001
BLOCKCHAIN_SERVICE_TIMEOUT=10
TXTBOX_API_KEY=
GATEWAYHUB_BASE_URL=https://gatewayhub.io
GATEWAYHUB_TIMEOUT=15
GATEWAYHUB_API_KEY=
GATEWAYHUB_WEBHOOK_SECRET=
EIS_ENVIRONMENT=sandbox
EIS_BASE_URL=
EIS_TIMEOUT=30
EIS_PUBLIC_KEY_PATH=
EIS_CALLBACK_URL=

# Polygon anchoring sidecar:
# - POLYGON_RPC_URL should point to your Polygon RPC provider.
# - POLYGON_PRIVATE_KEY should be the backend Polygon wallet private key
#   used for anchoring transactions, such as a dedicated Coins.ph wallet.
# - DOCUMENT_NOTARY_ADDRESS should be the deployed DocumentNotary contract.
# - POLYGON_NETWORK is a label surfaced in health responses and logs.
POLYGON_NETWORK=amoy

# Default to the Linux/OpenSSL path used in CI and production droplets.
DOCUTRUST_OPENSSL_CONFIG=/etc/ssl/openssl.cnf
# Windows local override example:
# DOCUTRUST_OPENSSL_CONFIG=C:\\php\\extras\\ssl\\openssl.cnf
DOCUTRUST_ROOT_CA_NAME="DocuTrust Root CA"
DOCUTRUST_ROOT_CA_COUNTRY=PH
DOCUTRUST_ROOT_CA_VALID_DAYS=3650
DOCUTRUST_SIGNER_CERT_VALID_DAYS=825
DOCUTRUST_SIGNING_BACKEND=app_managed

# Signature compliance (early production: HSM/KMS/PKCS#11 off)
SIGNATURE_COMPLIANCE_PHASE=early_production
SIGNATURE_ENGINE=basic
SIGNATURE_HSM_ENABLED=false
SIGNATURE_AWS_CLOUDHSM_ENABLED=false
SIGNATURE_AWS_KMS_ENABLED=false
SIGNATURE_PKCS11_ENABLED=false
SIGNATURE_PADES_ENABLED=false
HSM_BACKEND=disabled
HSM_ROUTES_ENABLED=false
HSM_MONITORING_ENABLED=false
SIGNATURE_OCSP_ROUTES_ENABLED=false
SIGNATURE_CRL_ROUTES_ENABLED=false
SIGNATURE_SCEP_CMP_ROUTES_ENABLED=false

POLYGON_RPC_URL=
POLYGON_PRIVATE_KEY=
DOCUMENT_NOTARY_ADDRESS=

# CSC remote signing / TSP provider settings for DocuTrust app
REMOTE_SIGNING_PROVIDER_NAME=docutrust_tsp
REMOTE_SIGNING_BASE_URL=http://127.0.0.1:3001
REMOTE_SIGNING_TIMEOUT=10
REMOTE_SIGNING_API_KEY=
REMOTE_SIGNING_API_MODE=csc
REMOTE_SIGNING_DEFAULT_CREDENTIAL_ID=
REMOTE_SIGNING_CSC_SIGN_HASH_ENDPOINT=/csc/v1/signatures/signHash
REMOTE_SIGNING_CSC_TIMESTAMP_ENDPOINT=/csc/v1/signatures/timestamp
REMOTE_SIGNING_CSC_AUTHORIZE_ENDPOINT=/csc/v2/credentials/authorize
REMOTE_SIGNING_CSC_AUTHORIZE_CHECK_ENDPOINT=/csc/v2/credentials/authorizeCheck
REMOTE_SIGNING_CSC_HASH_ALGORITHM=2.16.840.1.101.3.4.2.1
REMOTE_SIGNING_CSC_SIGN_ALGORITHM=1.2.840.113549.1.1.11
REMOTE_SIGNING_CSC_AUTHORIZATION_MODE=explicit
REMOTE_SIGNING_CSC_TIMESTAMP_ENABLED=false
# Windows example:
# REMOTE_SIGNING_CSC_TIMESTAMP_OPENSSL_BINARY=C:\Program Files\Git\mingw64\bin\openssl.exe
REMOTE_SIGNING_CSC_TIMESTAMP_OPENSSL_BINARY=
REMOTE_SIGNING_CSC_TIMESTAMP_TRUST_CERT_PATH=

# CSC remote signing / TSP sidecar settings for blockchain-service
CSC_PROVIDER_NAME=docutrust_tsp
CSC_SERVICE_API_KEY=
CSC_CREDENTIAL_ID=
CSC_SIGNER_PRIVATE_KEY_PATH=
CSC_SIGNER_CERT_PATH=
CSC_ISSUER_CERT_PATH=
CSC_SIGNATURE_ALGORITHM=1.2.840.113549.1.1.11
CSC_SCAL=2
CSC_AUTHORIZATION_MODE=explicit
CSC_AUTHORIZATION_TTL_SECONDS=600
CSC_TIMESTAMP_ENABLED=false
# Windows example:
# CSC_OPENSSL_BINARY=C:\Program Files\Git\mingw64\bin\openssl.exe
CSC_OPENSSL_BINARY=
CSC_TSA_CERT_PATH=
CSC_TSA_KEY_PATH=
CSC_TSA_ISSUER_CERT_PATH=
CSC_TSA_POLICY_OID=1.2.3.4.1

# Marketing site AI assistant (OpenAI / ChatGPT) — requires: composer require openai-php/client
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT=30
MARKETING_CHATBOT_ENABLED=true

# eKYC name matching (requires Tesseract OCR installed for local/production)
# EKYC_OCR_DRIVER=tesseract
# EKYC_TESSERACT_BINARY=tesseract
# EKYC_TESSERACT_LANG=eng
# EKYC_NAME_MATCH_THRESHOLD=85
