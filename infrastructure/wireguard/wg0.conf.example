# WireGuard VPN Configuration
# Connects DigitalOcean VPC to AWS VPC for CloudHSM access
#
# Install: apt install wireguard
# Enable: systemctl enable wg-quick@wg0
# Start:  systemctl start wg-quick@wg0

[Interface]
# DigitalOcean App Server
Address = 10.100.0.2/24
PrivateKey = <GENERATE_WITH: wg genkey>
ListenPort = 51820

# DNS for AWS internal resolution
DNS = 10.0.0.2

# Post-up rules to route HSM traffic through tunnel
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

[Peer]
# AWS VPC Gateway
PublicKey = <AWS_PEER_PUBLIC_KEY>
Endpoint = <AWS_VPN_GATEWAY_IP>:51820
AllowedIPs = 10.0.0.0/16
PersistentKeepalive = 25
